---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import WhatIsOdio from '../components/WhatIsOdio.astro';
import Features from '../components/Features.astro';
import StreamingServices from '../components/StreamingServices.astro';
import Comparison from '../components/Comparison.astro';
import GetStarted from '../components/GetStarted.astro';
import Faq from '../components/Faq.astro';
import Contribute from '../components/Contribute.astro';
import Activity from '../components/Activity.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <main id="main">
    <Hero />
    <WhatIsOdio />
    <Features />
    <StreamingServices />
    <Comparison />
    <GetStarted />
    <Faq />
    <Manifesto />
    <Contribute />
    <Activity />
  </main>
  <Footer />
</Base>

<style>
  /* Alternating section backgrounds — automatic, positional, mirrors how-it-works.
     No section hardcodes its own background, so the cadence can never drift.
     nth-of-type (not nth-child): components emit sibling <script type="ld+json">
     nodes inside <main>, which would otherwise shift the count and break parity. */
  #main :global(section:nth-of-type(odd)) {
    background-color: var(--color-bg);
  }
  #main :global(section:nth-of-type(even)) {
    background-color: var(--color-surface);
  }
  #main :global(section:not(:first-of-type)) {
    border-top: 1px solid var(--color-border);
  }
</style>
