---
import { execSync } from 'child_process';

let version = 'unknown';
try {
  version = execSync('git describe --tags --always --dirty', { encoding: 'utf8' }).trim();
} catch {}

const deps = [
  { name: 'Debian', url: 'https://www.debian.org/' },
  { name: 'MPD', url: 'https://www.musicpd.org/' },
  { name: 'PulseAudio', url: 'https://www.freedesktop.org/wiki/Software/PulseAudio/' },
  { name: 'Shairport Sync', url: 'https://github.com/mikebrady/shairport-sync' },
  { name: 'Snapcast', url: 'https://github.com/badaix/snapcast' },
  { name: 'upmpdcli', url: 'https://www.lesbonscomptes.com/upmpdcli/' },
  { name: 'Home Assistant', url: 'https://www.home-assistant.io/' },
];

const hostedBy = [
  { name: 'GitHub', url: 'https://github.com/', label: 'CI' },
  { name: 'Vercel', url: 'https://vercel.com/', label: 'hosting' },
  { name: 'OVH', url: 'https://www.ovh.com/', label: 'DNS' },
];
---

<footer
  class="py-12 px-6 border-t"
  style="background-color: var(--color-surface); border-color: var(--color-border);"
>
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <!-- Left: license + attribution -->
      <div class="space-y-3">
        <p class="text-sm" style="color: var(--color-muted);">
          odio.love is released under the
          <a
            href="https://github.com/b0bbywan/odios/blob/main/LICENSE"
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-2 transition-colors"
            style="color: var(--color-muted);"
            onmouseover="this.style.color='var(--color-leaf)'"
            onmouseout="this.style.color='var(--color-muted)'"
          >BSD 2-Clause License</a>.
        </p>
        <p class="text-sm" style="color: var(--color-border);">
          Built on the shoulders of:
          {deps.map((dep, i) => (
            <>
              <a
                href={dep.url}
                target="_blank"
                rel="noopener noreferrer"
                class="transition-colors underline underline-offset-2"
                style="color: var(--color-border);"
                onmouseover="this.style.color='var(--color-muted)'"
                onmouseout="this.style.color='var(--color-border)'"
              >{dep.name}</a>{i < deps.length - 1 ? ', ' : '.'}
            </>
          ))}
        </p>
        <p class="text-sm" style="color: var(--color-subtle);">
          Hosted by:
          {hostedBy.map((svc, i) => (
            <>
              <a
                href={svc.url}
                target="_blank"
                rel="noopener noreferrer"
                title={svc.label}
                class="transition-colors underline underline-offset-2"
                style="color: var(--color-subtle);"
                onmouseover="this.style.color='var(--color-muted)'"
                onmouseout="this.style.color='var(--color-subtle)'"
              >{svc.name}</a>{i < hostedBy.length - 1 ? ', ' : '.'}
            </>
          ))}
        </p>
      </div>

      <!-- Right: GitHub links -->
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/b0bbywan/odios"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm transition-colors"
          style="color: var(--color-border);"
          onmouseover="this.style.color='var(--color-muted)'"
          onmouseout="this.style.color='var(--color-border)'"
          aria-label="View odios on GitHub"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          b0bbywan
        </a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t" style="border-color: var(--color-border);">
      <p class="text-xs text-center" style="color: var(--color-border);">
        odio·love — Your Pi. Your music. No permission needed.
      </p>
      <p class="text-xs text-center font-mono mt-1" style="color: var(--color-border);">{version}</p>
    </div>
  </div>
</footer>
