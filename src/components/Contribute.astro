---
import { repos } from '../data/repos.js';
---

<section
  id="contribute"
  class="py-24 px-6"
  style="background-color: var(--color-bg);"
>
  <div class="max-w-3xl mx-auto text-center">
    <h2
      class="text-4xl md:text-5xl font-light mb-6 tracking-tight"
      style="font-family: var(--font-display); color: var(--color-text);"
    >
      Built in the open
    </h2>
    <p class="text-lg leading-relaxed mb-4" style="color: var(--color-muted);">
      odio exists because the tools it depends on — MPD, PulseAudio, Shairport Sync,
      Snapcast, upmpdcli — were built by people who chose openness. The same deal
      applies here.
    </p>
    <p class="text-lg leading-relaxed mb-12" style="color: var(--color-muted);">
      Every line is readable. Every binary is reproducible. Bug reports, patches,
      and opinionated configuration choices are all welcome.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      {repos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-start gap-1 px-5 py-4 rounded-lg border transition-colors min-w-[160px]"
          style="color: var(--color-muted); border-color: var(--color-border); background-color: var(--color-surface);"
          onmouseover="this.style.borderColor='var(--color-moss)';this.style.color='var(--color-text)'"
          onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-muted)'"
        >
          <div class="flex items-center justify-center gap-2 w-full">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="shrink: 0;">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span class="text-sm font-medium" style="font-family: var(--font-mono);">{repo.name}</span>
          </div>
          <span class="text-xs w-full text-center" style="color: var(--color-border);">{repo.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>
