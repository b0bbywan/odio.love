---
import { repos } from '../data/repos.js';
import { GitHub } from '../icons';
import TechIcon from './icons/TechIcon.astro';
---

<section
  id="contribute"
  class="py-24 px-6"
  style="background-color: var(--color-surface);"
>
  <div class="max-w-3xl mx-auto text-center">
    <h2
      class="text-4xl md:text-5xl font-light mb-6 tracking-tight"
      style="font-family: var(--font-display); color: var(--color-text);"
    >
      Built in the open
    </h2>
    <p class="text-lg leading-relaxed mb-4" style="color: var(--color-muted);">
      odio exists because the tools it depends on — MPD, PulseAudio, Shairport Sync,
      Snapcast, upmpdcli — were built by people who chose openness. The same deal
      applies here.
    </p>
    <p class="text-lg leading-relaxed mb-12" style="color: var(--color-muted);">
      Every line is readable. Every binary is reproducible. Bug reports, patches,
      and opinionated configuration choices are all welcome.
    </p>

    <div class="flex justify-center mb-10">
      <a
        href="/how-it-works"
        class="px-6 py-3 rounded-lg text-sm font-medium transition-colors"
        style="border: 1px solid var(--color-moss); color: var(--color-leaf);"
        onmouseover="this.style.backgroundColor='var(--color-moss)';this.style.color='var(--color-text)'"
        onmouseout="this.style.backgroundColor='transparent';this.style.color='var(--color-leaf)'"
        onfocus="this.style.backgroundColor='var(--color-moss)';this.style.color='var(--color-text)'"
        onblur="this.style.backgroundColor='transparent';this.style.color='var(--color-leaf)'"
      >
        How it works →
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-4">
      {repos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-start gap-1 px-5 py-4 rounded-lg border transition-colors min-w-[160px]"
          style="color: var(--color-muted); border-color: var(--color-border); background-color: var(--color-surface);"
          onmouseover="this.style.borderColor='var(--color-moss)';this.style.color='var(--color-text)'"
          onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-muted)'"
        >
          <div class="flex items-center justify-center gap-2 w-full">
            <GitHub width="14" height="14" aria-hidden="true" style="flex-shrink: 0;" />
            <span class="text-sm font-medium" style="font-family: var(--font-mono);">{repo.name}</span>
          </div>
          <div class="flex items-center justify-center gap-1.5 w-full">
            {repo.tech && <TechIcon name={repo.tech.label} color={repo.tech.color} size={12} />}
            <span class="text-xs" style="color: var(--color-subtle);">{repo.label}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
