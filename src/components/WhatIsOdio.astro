---
import { Content as WhatIsOdioContent } from '../content/what-is-odio.mdx';
import Slider from './Slider.svelte';

const stats = [
  { value: '< 50ms', label: 'p95 response time' },
  { value: '0 %', label: 'CPU at idle' },
  { value: '< 20 MB', label: 'RAM' },
];
---

<section
  id="what-is-odio"
  class="py-24 px-6 border-t"
  style="background-color: var(--color-surface); border-color: var(--color-border);"
>
  <div class="max-w-4xl mx-auto">
    <div class="what-is-odio-prose mb-16 max-w-2xl">
      <WhatIsOdioContent />
    </div>

    <!-- Screenshots slider -->
    <div class="mb-16">
      <Slider client:visible />
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {stats.map((stat) => (
        <div
          class="rounded-xl p-6 border text-center"
          style="background-color: var(--color-bg); border-color: var(--color-border);"
        >
          <div
            class="text-3xl md:text-4xl font-light mb-2 tracking-tight"
            style="font-family: var(--font-display); color: var(--color-amber);"
          >
            {stat.value}
          </div>
          <div class="text-sm" style="color: var(--color-muted);">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- How it works CTA -->
    <div class="mt-10 flex justify-center gap-4">
      <a
        href="/how-it-works"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors"
        style="background-color: var(--color-moss); color: var(--color-text);"
        onmouseover="this.style.backgroundColor='var(--color-leaf)'"
        onmouseout="this.style.backgroundColor='var(--color-moss)'"
      >
        How it works →
      </a>
      <a
        href="https://docs.odio.love"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors"
        style="background-color: var(--color-bg); color: var(--color-text);"
        onmouseover="this.style.backgroundColor='var(--color-moss)'"
        onmouseout="this.style.backgroundColor='var(--color-bg)'"
      >
        Documentation ↗
      </a>
    </div>
  </div>
</section>

<style>
  .what-is-odio-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .what-is-odio-prose :global(p) {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
    text-align: justify;
  }

  .what-is-odio-prose :global(abbr[title]) {
    text-decoration: underline dotted;
    text-decoration-color: var(--color-moss);
    text-underline-offset: 3px;
    cursor: help;
    color: var(--color-text);
  }
</style>
