---
import { Content as WhatIsOdioContent } from '../content/what-is-odio.mdx';
import Slider from './Slider.svelte';
import { stats } from '../data/stats.js';
---

<section
  id="what-is-odio"
  class="py-24 px-6"
>
  <div class="max-w-4xl mx-auto">
    <!-- Screenshots slider -->
    <div class="mb-16">
      <Slider client:visible />
    </div>

    <div class="what-is-odio-prose mb-16 max-w-2xl mx-auto">
      <WhatIsOdioContent />
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {stats.map((stat) => (
        <div class="rounded-xl p-6 border text-center bg-bg border-border">
          <div class="text-3xl md:text-4xl font-light mb-2 tracking-tight font-display text-amber">
            {stat.value}
          </div>
          <div class="text-sm text-muted">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- How it works CTA -->
    <div class="mt-10 flex justify-center gap-4">
      <a
        href="/how-it-works"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors bg-moss text-text hover:bg-leaf"
      >
        How it works →
      </a>
      <a
        href="https://docs.odio.love"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors bg-bg text-text hover:bg-moss"
      >
        Documentation ↗
      </a>
    </div>
  </div>
</section>

