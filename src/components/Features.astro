---
import { features } from '../data/features.js';
---

<section
  id="features"
  class="py-24 px-6 bg-surface"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-light mb-4 tracking-tight font-display text-text">
      Everything. No paywall.
    </h2>
    <p class="text-lg mb-14 text-muted">
      Every protocol. Every source. Every room. Free.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map(({ icon: Icon, name, desc, docs }) => (
        <a
          href={`https://docs.odio.love${docs}`}
          target="_blank"
          rel="noopener"
          class="group rounded-xl p-6 border border-border hover:border-leaf flex flex-col gap-4 transition-colors relative no-underline bg-surface"
        >
          <span
            class="absolute top-3 right-3 text-sm text-subtle opacity-50 group-hover:text-leaf group-hover:opacity-100 transition-[color,opacity] duration-200"
            aria-hidden="true"
          >↗</span>
          <div class="flex items-center justify-center gap-3">
            <Icon
              width="22"
              height="22"
              class="shrink-0 text-moss group-hover:text-leaf transition-colors"
              aria-hidden="true"
            />
            <h3 class="font-medium text-text">{name}</h3>
          </div>
          <p class="text-sm leading-relaxed text-center text-muted">{desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>
