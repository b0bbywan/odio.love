---
import { services, iconMap } from '../data/streaming.js';
---

<section
  id="streaming"
  class="py-24 px-6 border-t bg-bg border-border"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-light mb-4 tracking-tight font-display text-text">
      Streaming services
    </h2>
    <p class="text-lg mb-12 text-muted">
      Your music sources, on your Pi. No extra cost.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((s) => (
        <a
          href={`https://docs.odio.love${s.docs}`}
          target="_blank"
          rel="noopener"
          class="service-card rounded-xl p-6 border flex flex-col gap-4 transition-colors relative bg-surface no-underline"
        >
          <span class="service-link-arrow absolute top-3 right-3" aria-hidden="true">↗</span>
          <div class="flex items-center justify-center gap-3 mb-2">
            {s.icon && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill={s.iconColor} aria-hidden="true" class="shrink-0">
                <path d={iconMap[s.icon].path} />
              </svg>
            )}
            {s.iconImg && (
              <img src={s.iconImg} alt="" width="22" height="22" aria-hidden="true" class="shrink-0" />
            )}
            <h3 class="font-medium text-text">{s.name}</h3>
          </div>
          <p class="text-sm leading-relaxed text-center text-muted">{s.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    border-color: var(--color-border);
  }
  .service-card:hover {
    border-color: var(--color-leaf);
  }
  .service-link-arrow {
    color: var(--color-subtle);
    font-size: 0.875rem;
    opacity: 0.5;
    transition: opacity 0.2s, color 0.2s;
  }
  .service-card:hover .service-link-arrow {
    color: var(--color-leaf);
    opacity: 1;
  }
</style>
