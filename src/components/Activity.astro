---
---

<section
  id="activity"
  class="py-20 px-6"
  style="background-color: var(--color-bg);"
  data-activity
  hidden
>
  <div class="max-w-4xl mx-auto text-center">
    <p
      class="text-sm mb-4"
      style="color: var(--color-subtle); font-family: var(--font-mono);"
      data-since
    >
    </p>
    <div class="flex flex-col gap-y-6 mb-8" data-kpis>
    </div>

    <div class="mb-10 max-w-md mx-auto" data-releases hidden>
      <p
        class="text-xs uppercase tracking-wider mb-3"
        style="font-family: var(--font-mono); color: var(--color-subtle);"
      >Latest releases</p>
      <ul class="flex flex-col gap-2 text-left" data-releases-list></ul>
    </div>

    <a
      href="https://docs.odio.love/community/activity/"
      class="inline-block px-5 py-2.5 rounded-lg text-sm transition-colors"
      style="border: 1px solid var(--color-moss); color: var(--color-leaf);"
      onmouseover="this.style.backgroundColor='var(--color-moss)';this.style.color='var(--color-text)'"
      onmouseout="this.style.backgroundColor='transparent';this.style.color='var(--color-leaf)'"
    >
      See full activity on docs →
    </a>
  </div>
</section>

<style>
  .release-row {
    border: 1px solid var(--color-border);
    transition: border-color 0.15s, background-color 0.15s;
  }
  .release-row:hover {
    border-color: var(--color-leaf);
    background-color: var(--color-surface);
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('[data-activity]');
  if (section) {
    const fmt = new Intl.NumberFormat('en-US');
    fetch('https://docs.odio.love/stats.json')
      .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
      .then((stats) => {
        const since = new Date(stats.since).toLocaleDateString('en-US', {
          month: 'long',
          year: 'numeric',
        });
        const sinceEl = section.querySelector<HTMLElement>('[data-since]');
        if (sinceEl) sinceEl.textContent = `SINCE ${since.toUpperCase()}`;

        type Kpi =
          | { value: string; label: string }
          | { primary: string; secondary: string; label: string };

        const rows: Kpi[][] = [
          [
            {
              primary: fmt.format(stats.totals.pr.merged),
              secondary: `−${fmt.format(stats.totals.pr.closedUnmerged)}`,
              label: 'PRs merged / closed',
            },
            { value: fmt.format(stats.totals.commits), label: 'commits' },
            {
              primary: `+${fmt.format(stats.totals.locAdded)}`,
              secondary: `−${fmt.format(stats.totals.locRemoved)}`,
              label: 'lines added / removed',
            },
          ],
          [
            { value: fmt.format(stats.totals.releases), label: 'releases' },
            { value: `${fmt.format(stats.totals.stars)}★`, label: 'stars' },
          ],
        ];

        const singleCls =
          'text-4xl md:text-5xl font-medium tabular-nums leading-none';
        const pairCls =
          'text-2xl md:text-3xl font-medium tabular-nums leading-tight';
        const monoStyle = 'font-family: var(--font-mono);';
        const leafStyle = `${monoStyle} color: var(--color-leaf);`;
        const subtleStyle = `${monoStyle} color: var(--color-subtle);`;
        const labelCls = 'text-xs mt-2 uppercase tracking-wider';
        const labelStyle = `${monoStyle} color: var(--color-muted);`;

        const renderKpi = (k: Kpi) => {
          const value =
            'primary' in k
              ? `
                  <div class="flex-1 flex flex-col items-end justify-center ${pairCls}">
                    <span style="${leafStyle}">${k.primary}</span>
                    <span style="${subtleStyle}">${k.secondary}</span>
                  </div>
                `
              : `
                  <div class="flex-1 flex items-center justify-center ${singleCls}" style="${leafStyle}">
                    ${k.value}
                  </div>
                `;
          return `
            <div class="flex flex-col items-center">
              ${value}
              <div class="${labelCls}" style="${labelStyle}">${k.label}</div>
            </div>
          `;
        };

        const host = section.querySelector<HTMLElement>('[data-kpis]');
        if (host) {
          host.innerHTML = rows
            .map(
              (row) => `
                <div class="flex flex-wrap justify-center items-stretch gap-x-10 gap-y-6">
                  ${row.map(renderKpi).join('')}
                </div>
              `
            )
            .join('');
        }
        section.hidden = false;
      })
      .catch(() => {});

    const RELEASES_KEY = 'odios_releases_v2';
    const RELEASES_TTL = 3600000; // 1h

    type Release = {
      tag_name: string;
      name: string | null;
      html_url: string;
      published_at: string;
      prerelease: boolean;
      draft: boolean;
      body: string | null;
    };

    function extractHighlights(body: string | null): string {
      if (!body) return '';
      const items: string[] = [];
      for (const line of body.split(/\r?\n/)) {
        const m = line.trim().match(/^[-*]\s+\*\*([^*]+)\*\*/);
        if (m) items.push(m[1].trim());
        if (items.length >= 3) break;
      }
      return items.join(' · ');
    }

    function renderReleases(releases: Release[]) {
      const wrap = section!.querySelector<HTMLElement>('[data-releases]');
      const host = section!.querySelector<HTMLElement>('[data-releases-list]');
      if (!wrap || !host) return;
      const stable = releases
        .filter((r) => !r.prerelease && !r.draft)
        .slice(0, 5);
      if (!stable.length) return;
      host.innerHTML = stable
        .map((r) => {
          const title = r.name && r.name.trim() ? r.name : r.tag_name;
          const date = new Date(r.published_at).toLocaleDateString('en-US', {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
          });
          const highlights = extractHighlights(r.body);
          return `
            <li>
              <a
                href="${r.html_url}"
                target="_blank"
                rel="noopener"
                class="release-row flex flex-col gap-1 px-4 py-3 rounded-lg"
                style="font-family: var(--font-mono); text-decoration: none;"
              >
                <div class="flex justify-between items-baseline gap-4">
                  <span style="color: var(--color-leaf);">${title}</span>
                  <span class="text-xs" style="color: var(--color-subtle);">${date}</span>
                </div>
                ${highlights ? `<div class="text-xs text-left" style="color: var(--color-muted);">${highlights}</div>` : ''}
              </a>
            </li>
          `;
        })
        .join('');
      wrap.hidden = false;
    }

    function fetchReleases() {
      const cached = localStorage.getItem(RELEASES_KEY);
      if (cached) {
        try {
          const { data, ts } = JSON.parse(cached);
          if (Date.now() - ts < RELEASES_TTL) {
            renderReleases(data);
            return;
          }
        } catch {}
      }
      fetch('https://api.github.com/repos/b0bbywan/odios/releases?per_page=20')
        .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
        .then((data: Release[]) => {
          localStorage.setItem(
            RELEASES_KEY,
            JSON.stringify({ data, ts: Date.now() })
          );
          renderReleases(data);
        })
        .catch(() => {});
    }

    if ('requestIdleCallback' in window) {
      requestIdleCallback(fetchReleases);
    } else {
      setTimeout(fetchReleases, 200);
    }
  }
</script>
