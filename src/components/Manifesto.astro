---
import { Content as ManifestoContent } from '../content/manifesto.mdx';
---

<section
  id="manifesto"
  class="py-24 px-6"
  style="background-color: var(--color-bg);"
>
  <div class="max-w-[65ch] mx-auto">
    <div
      class="manifesto-prose"
      style="font-family: var(--font-display); font-size: 1.25rem; line-height: 1.9; color: var(--color-text);"
    >
      <ManifestoContent />
    </div>
  </div>
</section>

<style>
  .manifesto-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.01em;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .manifesto-prose :global(p) {
    margin-bottom: 1.75rem;
    color: var(--color-text);
    font-weight: 300;
    text-align: justify;
  }

  .manifesto-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3.5rem 0;
  }

  .manifesto-prose :global(strong) {
    color: var(--color-leaf);
    font-weight: 500;
  }

  /* Opening line after each hr — slightly larger, acts as a pull quote */
  .manifesto-prose :global(hr + p) {
    font-size: 1.35rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-text);
  }
</style>
