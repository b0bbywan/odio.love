---
import { installCmd, compatibleHardware, verifiedPlatforms, verifiedOther, imagerManifestUrl } from '../data/config.js';
import { Flag, Terminal, Copy, Check } from '../icons';
import { buildGetStartedSchema } from '../data/schemas/get-started.js';

const howToJsonLd = buildGetStartedSchema({ installCmd, imagerManifestUrl });
---

<section
  class="py-24 px-6"
  id="get-started"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-light mb-4 tracking-tight font-display text-text">
      Get started
    </h2>
    <p class="text-lg mb-12 text-muted">
      Two paths. Same destination.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6" style="grid-template-rows: subgrid;">
      <!-- Flash an image -->
      <div
        class="rounded-xl p-8 border grid grid-cols-1 gap-4 row-span-4 min-w-0 overflow-hidden bg-bg border-moss"
        style="grid-template-rows: subgrid;"
      >
        <div class="flex items-center gap-3">
          <Flag width="24" height="24" class="text-moss" aria-hidden="true" />
          <h3 class="text-xl font-medium text-text">Flash an image</h3>
        </div>
        <p class="text-sm leading-relaxed text-muted">
          Use <a href="https://www.raspberrypi.com/software/" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 text-leaf">Raspberry Pi Imager</a> with a custom repository URL. Configure hostname, SSH & WiFi, then flash.
        </p>
        <div class="self-end w-full rounded-lg border flex items-center bg-surface border-border">
          <span
            class="text-xs flex-1 min-w-0 overflow-x-auto whitespace-nowrap px-4 py-3 font-mono text-leaf"
            id="gs-manifest-url"
          >{imagerManifestUrl}</span>
          <button
            data-copy-source="gs-manifest-url"
            class="shrink-0 p-1.5 mr-2 rounded cursor-pointer transition-colors text-muted hover:text-leaf"
            title="Copy"
          >
            <Copy width="14" height="14" />
            <Check class="check" width="14" height="14" style="display:none" />
          </button>
        </div>
        <ul class="flex flex-col gap-1.5 text-xs text-subtle">
          <li>Imager → Options App → Content Repository → Use custom URL</li>
          <li>Available in armhf (32-bit) and arm64 (64-bit)</li>
        </ul>
      </div>

      <!-- Install on Debian -->
      <div
        class="rounded-xl p-8 border grid grid-cols-1 gap-4 row-span-4 min-w-0 overflow-hidden bg-bg border-moss"
        style="grid-template-rows: subgrid;"
      >
        <div class="flex items-center gap-3">
          <Terminal width="24" height="24" class="text-leaf" aria-hidden="true" />
          <h3 class="text-xl font-medium text-text">Install on Debian / Pi OS</h3>
        </div>
        <p class="text-sm leading-relaxed text-muted">
          Debian 13 (trixie) and Ubuntu compatible. The installer handles all dependencies and services.
        </p>
        <div class="self-end w-full rounded-lg border flex items-center bg-surface border-border">
          <span
            class="text-xs flex-1 min-w-0 overflow-x-auto whitespace-nowrap px-4 py-3 font-mono text-leaf"
            id="gs-install-cmd"
          >{installCmd}</span>
          <button
            data-copy-source="gs-install-cmd"
            class="shrink-0 p-1.5 mr-2 rounded cursor-pointer transition-colors text-muted hover:text-leaf"
            title="Copy"
          >
            <Copy width="14" height="14" />
            <Check class="check" width="14" height="14" style="display:none" />
          </button>
        </div>
        <ul class="flex flex-col gap-1.5 text-xs text-subtle">
          <li>{'~800 MB - ~5 min on x86, <15 min on Pi 3B+, up to 1h20 on a Pi B+ at 800 MHz'}</li>
        </ul>
      </div>
    </div>

    <p class="text-sm mb-6 text-amber">
      Tip: set up DAC and overclocking (armhf) in /boot/firmware/config.txt beforehand to save a reboot.
    </p>

    <p class="text-sm mb-14 text-muted">
      Need help? Check the <a
        href="https://docs.odio.love"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-2 transition-colors text-leaf hover:text-text"
      >documentation</a> for detailed guides and API reference.
    </p>

    <!-- Compatible hardware -->
    <div>
      <h3 class="text-lg font-medium mb-5 text-text">Compatible hardware</h3>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {compatibleHardware.map((hw) => (
          <li class="flex items-center gap-2.5 text-sm text-muted">
            <Check width="14" height="14" class="text-moss shrink-0" aria-hidden="true" />
            {hw}
          </li>
        ))}
      </ul>
    </div>

    <!-- Beta disclaimer -->
    <div class="mt-10 rounded-xl px-6 py-5 border flex flex-col gap-3 bg-bg border-border">
      <p class="text-base text-muted">
        odio is in <strong class="text-amber">beta</strong> — daily use is solid. Install and upgrade paths can still hit edge cases across the long tail of hardware.
        Try it on yours, <a
          href="https://github.com/b0bbywan/odios/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition-colors text-leaf hover:text-text"
        >report bugs</a> and help grow the list.
      </p>
      <div>
        <p class="text-xs uppercase tracking-widest mb-3 text-subtle">
          Verified on -
          <a
            href="https://github.com/b0bbywan/odios/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-2 transition-colors normal-case tracking-normal text-subtle hover:text-muted"
          >add yours ↗</a>
        </p>
        <div class="flex flex-col gap-2">
          {verifiedPlatforms.map((p) => (
            <div class="flex items-baseline gap-3">
              <span class={`text-xs font-mono shrink-0 w-14 ${p.incoming ? 'text-subtle' : 'text-amber'}`}>{p.arch}</span>
              {p.incoming
                ? <span class="text-xs italic text-subtle">incoming…</span>
                : <span class="text-sm text-muted">{p.examples.join(', ')}</span>
              }
            </div>
          ))}
          <div class="flex items-baseline gap-3 mt-1 pt-2 border-t border-border">
            <span class="text-xs font-mono shrink-0 w-14 text-subtle">other</span>
            <span class="text-sm text-subtle">
              {verifiedOther.map((o) => `${o.label} (${o.note})`).join(', ')}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
