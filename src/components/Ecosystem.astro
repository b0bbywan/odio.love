---
import { ecosystemProjects } from '../data/ecosystem.js';
import { ecosystemCountLabel } from '../data/config.js';
import { GitHub } from '../icons';
---

<section class="py-24 px-6 bg-bg">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-light mb-4 tracking-tight font-display text-text">
      The ecosystem
    </h2>
    <p class="text-lg mb-12 text-muted">
      {ecosystemCountLabel} repositories. One coherent stack.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {ecosystemProjects.map((project) => (
        <div class="rounded-xl p-7 border flex flex-col gap-4 transition-colors hover:border-moss bg-surface border-border">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-xl font-medium tracking-tight font-mono text-text">{project.name}</h3>
            <div class="flex items-center gap-2 shrink-0">
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs px-3 py-1.5 rounded border transition-colors text-muted border-border"
                aria-label={`View ${project.name} on GitHub`}
              >
                <GitHub width="14" height="14" class="inline mr-1" aria-hidden="true" />
                GitHub
              </a>
              {project.live && (
                <a
                  href={project.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs px-3 py-1.5 rounded border transition-colors text-leaf border-moss"
                  aria-label={`Visit ${project.name} live site`}
                >
                  Live ↗
                </a>
              )}
            </div>
          </div>
          <p class="text-sm leading-relaxed text-muted">
            {project.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
