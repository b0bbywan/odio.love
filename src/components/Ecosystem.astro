---
import { repos } from '../data/repos.js';
import TechIcon from './icons/TechIcon.astro';
---

<div class="grid mb-16 gap-4" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
  {repos.map((project) => (
    <div class="relative flex flex-col">
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="ecosystem-card flex-1 rounded-lg p-4 border flex flex-col gap-2 transition-colors no-underline bg-bg border-border"
        aria-label={`View ${project.name} on GitHub`}
      >
        <span class="ecosystem-link-arrow absolute top-2 right-2" aria-hidden="true">↗</span>
        <div class="flex items-center gap-2">
          {project.tech && <TechIcon name={project.tech.label} color={project.tech.color} size={14} />}
          <h3 class="font-mono text-sm font-medium text-text m-0">{project.name}</h3>
        </div>
        <p class="text-xs leading-snug text-muted m-0">{project.desc}</p>
      </a>
      {project.live && (
        <a
          href={project.live}
          target="_blank"
          rel="noopener noreferrer"
          class="absolute top-2 right-7 text-[10px] px-1.5 py-0.5 rounded border border-moss text-leaf no-underline hover:bg-moss hover:text-text transition-colors"
          aria-label={`Visit ${project.name} live site`}
        >
          Live
        </a>
      )}
    </div>
  ))}
</div>

<style>
  .ecosystem-card:hover {
    border-color: var(--color-leaf);
  }
  .ecosystem-link-arrow {
    color: var(--color-subtle);
    font-size: 0.875rem;
    opacity: 0.5;
    transition: opacity 0.2s, color 0.2s;
  }
  .ecosystem-card:hover .ecosystem-link-arrow {
    color: var(--color-leaf);
    opacity: 1;
  }
</style>
