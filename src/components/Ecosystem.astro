---
import { repos } from '../data/repos.js';
import TechIcon from './icons/TechIcon.astro';
---

<div class="grid mb-16 gap-4" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
  {repos.map((project) => (
    <div class="relative flex flex-col">
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="ecosystem-card group flex-1 rounded-lg p-4 border border-border hover:border-leaf flex flex-col gap-2 transition-colors no-underline bg-bg"
        aria-label={`View ${project.name} on GitHub`}
      >
        <span
          class="absolute top-2 right-2 text-sm text-subtle opacity-50 group-hover:text-leaf group-hover:opacity-100 transition-[color,opacity] duration-200"
          aria-hidden="true"
        >↗</span>
        <div class="flex items-center gap-2">
          {project.tech && <TechIcon name={project.tech.label} color={project.tech.color} size={12} />}
          <h3 class="font-mono text-base font-medium text-text m-0">{project.name}</h3>
        </div>
        <p class="text-xs leading-snug text-muted m-0">{project.desc}</p>
      </a>
      {project.live && (
        <a
          href={project.live}
          target="_blank"
          rel="noopener noreferrer"
          class="absolute top-2 right-7 text-[10px] px-1.5 py-0.5 rounded border border-moss text-leaf no-underline hover:bg-moss hover:text-text transition-colors"
          aria-label={`Visit ${project.name} live site`}
        >
          Live
        </a>
      )}
    </div>
  ))}
</div>

<style>
  /* Escape .how-prose cascade (parent MDX page forces <p> to 1.125rem/justify/colored) */
  .ecosystem-card p {
    font-size: 0.9rem;
    line-height: 1.45;
    text-align: left;
    margin: 0;
  }
  .ecosystem-card h3 {
    margin: 0;
  }
</style>

