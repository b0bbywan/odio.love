---
import { ecosystemProjects } from '../data/ecosystem.js';
---

<section
  class="py-24 px-6"
  style="background-color: var(--color-bg);"
>
  <div class="max-w-4xl mx-auto">
    <h2
      class="text-4xl md:text-5xl font-light mb-4 tracking-tight"
      style="font-family: var(--font-display); color: var(--color-text);"
    >
      The ecosystem
    </h2>
    <p class="text-lg mb-12" style="color: var(--color-muted);">
      Six repositories. One coherent stack.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {ecosystemProjects.map((project) => (
        <div
          class="rounded-xl p-7 border flex flex-col gap-4 transition-colors hover:border-moss"
          style="background-color: var(--color-surface); border-color: var(--color-border);"
        >
          <div class="flex items-start justify-between gap-4">
            <h3
              class="text-xl font-medium tracking-tight"
              style="font-family: var(--font-mono); color: var(--color-text);"
            >{project.name}</h3>
            <div class="flex items-center gap-2 shrink-0">
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs px-3 py-1.5 rounded border transition-colors"
                style="color: var(--color-muted); border-color: var(--color-border);"
                aria-label={`View ${project.name} on GitHub`}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="inline mr-1" aria-hidden="true">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                GitHub
              </a>
              {project.live && (
                <a
                  href={project.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs px-3 py-1.5 rounded border transition-colors"
                  style="color: var(--color-leaf); border-color: var(--color-moss);"
                  aria-label={`Visit ${project.name} live site`}
                >
                  Live ↗
                </a>
              )}
            </div>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
            {project.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
