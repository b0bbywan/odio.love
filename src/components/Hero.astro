---
import { installCmd } from '../data/config.js';
import { Copy, Check, ArrowDown } from '../icons';
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden bg-bg">
  <!-- SVG noise texture -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none" aria-hidden="true">
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)" />
  </svg>

  <!-- Subtle radial glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(74,124,89,0.08) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full flex flex-col items-center text-center max-w-3xl mx-auto gap-8">
    <!-- Logo -->
    <img
      src="/logo.png"
      alt="odio logo"
      width="80"
      height="80"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-20 h-20 object-contain"
      onerror="this.style.display='none'"
    />

    <!-- Title -->
    <h1 class="flex flex-col items-center gap-3 font-light tracking-tight leading-none">
      <span class="font-display text-6xl sm:text-7xl md:text-8xl">
        odio<span class="text-amber">·</span>love
      </span>
      <span class="font-body text-lg sm:text-xl text-muted leading-snug tracking-normal">
        Revive any Raspberry Pi as an open-source audio streamer
      </span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl sm:text-2xl font-light leading-relaxed text-muted">
      That Pi in your drawer?<br />
      <span class="text-text">It's already a €400 streamer.</span>
    </p>

    <!-- Install command -->
    <div class="w-full max-w-2xl rounded-lg border flex items-center bg-surface border-border">
      <span
        class="text-xs sm:text-sm flex-1 min-w-0 overflow-x-auto whitespace-nowrap px-4 py-3 font-mono text-leaf"
        id="install-cmd"
      >{installCmd}</span>
      <button
        data-copy-source="install-cmd"
        class="shrink-0 p-1.5 mr-2 rounded cursor-pointer transition-colors text-muted hover:text-leaf"
        title="Copy"
      >
        <Copy width="14" height="14" />
        <Check class="check" width="14" height="14" style="display:none" />
      </button>
    </div>

    <!-- Headline -->
    <p class="text-base sm:text-lg font-light text-muted">
      Flash an SD card. Your Pi wakes up as a full streamer, ready for Home Assistant.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a
        href="#get-started"
        class="px-6 py-3 rounded-lg font-medium transition-colors bg-moss text-text hover:bg-leaf"
      >
        Get started ↓
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-border"
    aria-hidden="true"
  >
    <ArrowDown width="24" height="24" />
  </div>
</section>
