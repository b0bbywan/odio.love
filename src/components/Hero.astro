---
import { installCmd } from '../data/config.js';
---

<section
  class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden"
  style="background-color: var(--color-bg);"
>
  <!-- Header links -->
  <div class="absolute top-5 right-6 flex items-center gap-4 z-20">
    <a
      href="https://github.com/b0bbywan/odios"
      target="_blank"
      rel="noopener noreferrer"
      title="odios — installer"
      class="flex items-center gap-1.5 text-xs transition-colors"
      style="color: var(--color-muted);"
      onmouseover="this.style.color='var(--color-text)'"
      onmouseout="this.style.color='var(--color-muted)'"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      odios
    </a>
    <a
      href="https://my.home-assistant.io/redirect/hacs_repository/?owner=b0bbywan&repository=odio-ha&category=integration"
      target="_blank"
      rel="noopener noreferrer"
      title="odio-ha — Home Assistant"
      class="hidden sm:block"
    >
      <img
        src="https://my.home-assistant.io/badges/hacs_repository.svg"
        alt="Add odio-ha to HACS"
        style="height: 20px; width: auto;"
      />
    </a>
    <a
      href="https://pwa.odio.love"
      target="_blank"
      rel="noopener noreferrer"
      title="odio PWA"
      class="hidden sm:flex items-center gap-1.5 text-xs transition-colors"
      style="color: var(--color-muted);"
      onmouseover="this.style.color='var(--color-text)'"
      onmouseout="this.style.color='var(--color-muted)'"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="5" y="2" width="14" height="20" rx="2" />
        <line x1="12" y1="18" x2="12" y2="18.01" />
      </svg>
      pwa
    </a>
  </div>

  <!-- SVG noise texture -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none" aria-hidden="true">
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)" />
  </svg>

  <!-- Subtle radial glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(74,124,89,0.08) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full flex flex-col items-center text-center max-w-3xl mx-auto gap-8">
    <!-- Logo -->
    <img
      src="/logo.png"
      alt="odio logo"
      width="80"
      height="80"
      class="w-20 h-20 object-contain"
      onerror="this.style.display='none'"
    />

    <!-- Title -->
    <h1
      class="text-6xl sm:text-7xl md:text-8xl font-light tracking-tight leading-none"
      style="font-family: var(--font-display);"
    >
      odio<span style="color: var(--color-amber);">·</span>love
    </h1>

    <!-- Tagline -->
    <p
      class="text-xl sm:text-2xl font-light leading-relaxed"
      style="color: var(--color-muted);"
    >
      That Pi in your drawer?<br />
      <span style="color: var(--color-text);">It's already a €400 streamer.</span>
    </p>

    <!-- Install command -->
    <div
      class="w-full max-w-2xl rounded-lg border px-4 py-3 flex items-center gap-3 overflow-hidden"
      style="background-color: var(--color-surface); border-color: var(--color-border);"
    >
      <span
        class="text-xs sm:text-sm flex-1 min-w-0 text-center sm:text-left overflow-x-auto whitespace-nowrap"
        style="font-family: var(--font-mono); color: var(--color-leaf);"
        id="install-cmd"
      >{installCmd}</span>
      <button
        id="copy-btn"
        onclick="navigator.clipboard.writeText(document.getElementById('install-cmd').textContent).then(()=>{this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)})"
        class="hidden sm:block shrink-0 text-xs px-3 py-1.5 rounded border transition-colors cursor-pointer"
        style="font-family: var(--font-mono); color: var(--color-muted); border-color: var(--color-border);"
      >Copy</button>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a
        href="#manifesto"
        class="px-6 py-3 rounded-lg font-medium transition-colors"
        style="background-color: var(--color-moss); color: var(--color-text);"
        onmouseover="this.style.backgroundColor='var(--color-leaf)'"
        onmouseout="this.style.backgroundColor='var(--color-moss)'"
      >
        Read the manifesto ↓
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"
    style="color: var(--color-border);"
    aria-hidden="true"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12l7 7 7-7" />
    </svg>
  </div>
</section>
