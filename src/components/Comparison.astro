---
import { comparisonRows } from '../data/comparison.js';
---

<section
  id="comparison"
  class="py-24 px-6 border-t bg-bg border-border"
>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-light mb-4 tracking-tight font-display text-text">
      What freedom costs elsewhere
    </h2>
    <p class="text-lg mb-12 text-muted">
      The same features. Very different terms.
    </p>

    <div class="overflow-x-auto rounded-xl border border-border">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-bg">
            <th class="text-left px-5 py-4 font-medium border-b text-muted border-border">Feature</th>
            <th class="text-center px-5 py-4 font-medium border-b border-l text-amber border-border border-l-amber">odio</th>
            <th class="text-center px-5 py-4 font-medium border-b border-l text-muted border-border">Volumio (free)</th>
            <th class="text-center px-5 py-4 font-medium border-b border-l text-muted border-border">Commercial</th>
          </tr>
        </thead>
        <tbody>
          {comparisonRows.map((row, i) => (
            <tr class={i % 2 === 0 ? 'bg-surface' : 'bg-bg'}>
              <td class="px-5 py-3.5 border-b text-text border-border">{row.feature}</td>
              <td class={`px-5 py-3.5 border-b border-l text-center font-medium border-border border-l-2 border-l-amber ${row.odio.positive ? 'text-leaf' : 'text-muted'}`}>{row.odio.value}</td>
              <td class={`px-5 py-3.5 border-b border-l text-center border-border ${row.volumio.positive ? 'text-leaf' : 'text-muted'}`}>{row.volumio.value}</td>
              <td class={`px-5 py-3.5 border-b border-l text-center border-border ${row.commercial.positive ? 'text-leaf' : 'text-muted'}`}>{row.commercial.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
