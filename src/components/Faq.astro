---
import { faq } from '../data/faq.js';

const orgRef = { '@id': 'https://odio.love/#organization' };
const softwareRef = { '@id': 'https://odio.love/#software' };

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://odio.love/#faq',
  inLanguage: 'en',
  about: softwareRef,
  publisher: orgRef,
  mainEntity: faq.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    inLanguage: 'en',
    answerCount: 1,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
      inLanguage: 'en',
      author: orgRef,
    },
  })),
};
---

<section
  id="faq"
  class="py-24 px-6"
  style="background-color: var(--color-bg);"
>
  <div class="max-w-3xl mx-auto">
    <h2
      class="text-4xl md:text-5xl font-light mb-6 tracking-tight text-center"
      style="font-family: var(--font-display); color: var(--color-text);"
    >
      Common questions
    </h2>
    <p class="text-lg leading-relaxed mb-12 text-center" style="color: var(--color-muted);">
      Things people keep asking on Reddit, GitHub, and DMs.
    </p>

    <div class="flex flex-col gap-3">
      {faq.map(({ q, a }) => (
        <details
          class="group rounded-lg border px-5 py-4 transition-colors"
          style="border-color: var(--color-border); background-color: var(--color-surface);"
        >
          <summary
            class="cursor-pointer list-none flex items-start justify-between gap-4 text-base font-medium"
            style="color: var(--color-text);"
          >
            <span>{q}</span>
            <span
              class="transition-transform group-open:rotate-45 text-xl leading-none flex-shrink-0"
              style="color: var(--color-leaf);"
              aria-hidden="true"
            >+</span>
          </summary>
          <p class="mt-3 text-base leading-relaxed" style="color: var(--color-muted);">
            {a}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
