---
import type { MDXInstance } from 'astro';
import { buildFaqSchema } from '../data/schemas/faq.js';

type FaqFrontmatter = { q: string; plainAnswer: string };

const faqModules = import.meta.glob<MDXInstance<FaqFrontmatter>>('../content/faq/*.mdx', { eager: true });
const entries = Object.entries(faqModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, m]) => m);

const jsonLd = buildFaqSchema({ entries });
---

<section
  id="faq"
  class="py-24 px-6 bg-bg"
>
  <div class="max-w-3xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-light mb-6 tracking-tight text-center font-display text-text">
      Common questions
    </h2>
    <p class="text-lg leading-relaxed mb-12 text-center text-muted">
      Things people keep asking on Reddit, GitHub, and DMs.
    </p>

    <div class="flex flex-col gap-3">
      {entries.map(({ frontmatter, Content }) => (
        <details class="group rounded-lg border px-5 py-4 transition-colors border-border bg-surface">
          <summary class="cursor-pointer list-none flex items-start justify-between gap-4 text-base font-medium text-text">
            <span>{frontmatter.q}</span>
            <span
              class="transition-transform group-open:rotate-45 text-xl leading-none shrink-0 text-leaf"
              aria-hidden="true"
            >+</span>
          </summary>
          <div class="faq-answer mt-3 text-base leading-relaxed text-muted">
            <Content />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
