---
import '../styles/global.css';
import pkg from '../../package.json';
import Header from '../components/Header.astro';
import {
  buildSiteSchema,
  DEFAULT_TITLE,
  DEFAULT_DESCRIPTION,
  OG_IMAGE,
} from '../data/schemas/site.js';
import cormorantLight from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-300-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = OG_IMAGE,
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const siteSchema = buildSiteSchema({ description, version: pkg.version });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <link rel="preload" href={cormorantLight} as="font" type="font/woff2" crossorigin />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="odio dashboard: AirPlay 2, Spotify, Snapcast, Bluetooth services on a Raspberry Pi" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="odio dashboard: AirPlay 2, Spotify, Snapcast, Bluetooth services on a Raspberry Pi" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <slot />
  </body>
</html>
